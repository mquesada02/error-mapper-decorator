{
  "name": "error-mapper-decorator",
  "version": "0.2.1",
  "description": "Tiny, type-safe error-mapping decorator",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:runtime": "tsc -p test/integration/legacy/tsconfig.json && node test/integration/legacy/dist/index.js && tsc -p test/integration/stage3/tsconfig.json && node test/integration/stage3/dist/index.js",
    "examples": "tsc -p examples/tsconfig.json && tsc -p examples/tsconfig.legacy.json && node examples/dist/basic-method.js && node examples/dist/whole-class.js && node examples/dist/pipeline-chaining.js",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:legacy": "tsc -p tsconfig.legacy.json --noEmit",
    "publint": "publint",
    "attw": "attw --pack",
    "docs": "typedoc",
    "mutation": "stryker run",
    "bench": "vitest bench --run",
    "verify": "pnpm lint && pnpm typecheck && pnpm typecheck:legacy && pnpm coverage && pnpm build && pnpm test:runtime && pnpm examples && pnpm publint && pnpm attw",
    "prepublishOnly": "pnpm verify"
  },
  "keywords": [
    "decorator",
    "error",
    "error-handling",
    "error-mapping",
    "exception",
    "typescript",
    "experimentalDecorators",
    "stage-3"
  ],
  "author": "mquesada",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mquesada02/error-mapper-decorator.git"
  },
  "bugs": {
    "url": "https://github.com/mquesada02/error-mapper-decorator/issues"
  },
  "homepage": "https://github.com/mquesada02/error-mapper-decorator#readme",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18",
    "@biomejs/biome": "^2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25",
    "@vitest/coverage-v8": "^4",
    "fast-check": "^4",
    "publint": "^0.3",
    "reflect-metadata": "^0.2",
    "tsup": "^8",
    "typedoc": "^0.28",
    "typescript": "^5",
    "vitest": "^4"
  },
  "pnpm": {
    "overrides": {
      "qs": "^6.15.2"
    }
  }
}
